# ============================================================
# osTicket Docker - Environment Variables Template
# ============================================================
# COPY ATAU RENAME KE .env DAN SESUAIKAN DENGAN KEBUTUHAN ANDA
# DO NOT COMMIT .env FILE TO GIT!

# ============================================================
# WEB SERVICE CONFIGURATION
# ============================================================

# Port untuk mengakses osTicket dari localhost
# Ubah jika port 8080 sudah terpakai
WEB_PORT=8080

# Port untuk mengakses phpMyAdmin dari localhost
# Ubah jika port 8081 sudah terpakai
PHPMYADMIN_PORT=8081

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# Database host - gunakan nama service (bukan localhost)
# Default: db (nama service di docker-compose.yml)
MYSQL_HOST=db

# Database port - gunakan port internal (bukan yang di publish)
# Default: 3306
MYSQL_PORT=3306

# Nama database yang akan dibuat
# Default: osticket
MYSQL_DATABASE=osticket

# Username untuk akses database
# Default: osticket
MYSQL_USER=osticket

# PASSWORD untuk database user - UBAH INI!
# Rekomendasi: Generate dengan password manager atau:
#   Linux/Mac: openssl rand -base64 32
#   Windows: [Convert]::ToBase64String((1..32|%{[byte](Get-Random -Max 256)}))
MYSQL_PASSWORD=osticketpass

# PASSWORD untuk root database - UBAH INI!
# Rekomendasi: Generate dengan password manager atau gunakan command di atas
MYSQL_ROOT_PASSWORD=rootpassword

# ============================================================
# TIMEZONE CONFIGURATION
# ============================================================

# Timezone untuk aplikasi PHP dan database
# Format: Timezone identifier (dari PHP list_timezones)
# Pilihan umum:
#   Asia/Jakarta (Indonesia WIB)
#   Asia/Bangkok (Thailand)
#   Asia/Manila (Filipina)
#   Asia/Kuala_Lumpur (Malaysia)
#   Asia/Singapore (Singapore)
#   Asia/Hong_Kong (Hong Kong)
#   Asia/Tokyo (Japan)
#   America/New_York (USA Eastern)
#   Europe/London (UK)
#   Europe/Paris (Central Europe)
#   Australia/Sydney (Australia)
TIMEZONE=Asia/Jakarta

# ============================================================
# PASSWORD SECURITY GUIDELINES
# ============================================================
#
# 1. PASSWORD HARUS KUAT:
#    - Minimal 12 karakter
#    - Kombinasi: uppercase, lowercase, numbers, symbols
#    - Contoh kuat: P@ssw0rd!Secure2024#osTicket
#
# 2. GENERATE PASSWORD KUAT:
#
#    Linux/Mac:
#    $ openssl rand -base64 32
#    $ head -c 32 /dev/urandom | base64
#
#    Windows PowerShell:
#    > [Convert]::ToBase64String((1..32 | % {[byte](Get-Random -Max 256)}))
#
#    Online Generator (HATI-HATI):
#    https://www.lastpass.com/password-generator/ (use offline)
#
# 3. JANGAN GUNAKAN:
#    - Password default (seperti di contoh ini)
#    - Password yang mudah ditebak (admin, 123456, password)
#    - Password yang sama dengan service lain
#    - Password yang mengandung info pribadi
#
# 4. MENYIMPAN PASSWORD:
#    - Gunakan password manager (KeePass, 1Password, Bitwarden)
#    - Simpan di tempat aman
#    - JANGAN simpan di file, commit ke git, atau share via chat
#
# ============================================================

# ============================================================
# OPTIONAL: ADVANCED CONFIGURATION
# ============================================================

# Database character set (jangan diubah untuk osTicket)
# MYSQL_CHARACTER_SET=utf8mb4

# Database collation (jangan diubah untuk osTicket)
# MYSQL_COLLATION=utf8mb4_unicode_ci

# ============================================================
# CONTOH KONFIGURASI UNTUK BERBAGAI SKENARIO
# ============================================================

# --- Development Environment ---
# WEB_PORT=8080
# MYSQL_PASSWORD=dev_password_123
# MYSQL_ROOT_PASSWORD=dev_root_pass_456
# TIMEZONE=Asia/Jakarta

# --- Staging Environment ---
# WEB_PORT=8080
# MYSQL_PASSWORD=staging_secure_pass_abc123!@#
# MYSQL_ROOT_PASSWORD=staging_root_secure_pass_xyz789!@#
# TIMEZONE=Asia/Jakarta

# --- Production Environment ---
# WEB_PORT=8080
# MYSQL_PASSWORD=Pr0duction!P@ssw0rd#2024$Secure&Random
# MYSQL_ROOT_PASSWORD=R00t!P@ssw0rd#2024$Secure&Random
# TIMEZONE=Asia/Jakarta
# (Noted: Pada production, gunakan reverse proxy & SSL)

# ============================================================
# POST-INSTALLATION CHECKLIST
# ============================================================
#
# [ ] Edit .env dengan password yang KUAT
# [ ] Tidak commit .env ke git/version control
# [ ] Test koneksi database sebelum production
# [ ] Ubah default admin password setelah instalasi
# [ ] Backup .env ke tempat aman
# [ ] Disable setup directory setelah instalasi
# [ ] Setup SSL certificate (production)
# [ ] Configure firewall rules
#
# ============================================================
