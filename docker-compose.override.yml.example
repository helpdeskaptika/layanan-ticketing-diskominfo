# ============================================================
# osTicket Docker Development Override Configuration
# ============================================================
# File ini untuk development mode (override production settings)
# Rename to docker-compose.override.yml untuk mengaktifkan

# Usage:
#   1. Copy atau rename ini ke docker-compose.override.yml
#   2. docker compose akan otomatis menggunakan override ini
#   3. Gunakan untuk development/debugging

version: '3.9'

services:
  web:
    # Enable debugging dan verbose output
    environment:
      - DEBUG=1
      - XDEBUG_MODE=develop,debug
    
    # Volume mounting untuk live code editing
    volumes:
      # Allow live editing dari host
      - ./src:/var/www/html:cached
      - ./php.ini:/usr/local/etc/php/conf.d/osticket.ini:ro
      - /var/www/html/node_modules  # Exclude node_modules
    
    # Port untuk debugging
    ports:
      - "9003:9003"  # Xdebug port
    
    # Rebuild on every start untuk development
    command: apache2-foreground

  db:
    # Volume dengan bind mount untuk easy backup
    volumes:
      - ./data/mysql:/var/lib/mysql
      - ./db_init.sql:/docker-entrypoint-initdb.d/init.sql:ro
    
    # Slower sync untuk stability
    command:
      - --character-set-server=utf8mb4
      - --collation-server=utf8mb4_unicode_ci
      - --max_allowed_packet=256M
      - --wait_timeout=28800
      - --interactive_timeout=28800
      - --slow_query_log=1
      - --slow_query_log_file=/var/log/mysql/slow.log
      - --long_query_time=2
